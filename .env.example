# ============================================================
# Copy file này thành .env và điền giá trị thật.
# File .env KHÔNG BAO GIỜ được commit lên git.
# ============================================================

# === MongoDB (Docker Compose substitution) ===
MONGO_USERNAME=admin
MONGO_PASSWORD=<strong-password>

# === Backend runtime ===
# Lưu ý: password trong URI phải được URL-encode (vd: @ -> %40)
MONGO_URI=mongodb://admin:<url-encoded-password>@mongo:27017/todo?authSource=admin
GMAIL_USERNAME=
GMAIL_PASSWORD=
PORT_BE=8386
JWT_SECRET=<random-secret-64-chars>
URL=https://api.example.com
PUBLIC_URL=https://api.example.com

# === Frontend (build-time, truyền vào docker build arg) ===
REACT_APP_API_URL=https://api.example.com/api

# === Pipeline (chỉ dùng trên máy local, không copy lên VPS) ===
GITHUB_TOKEN=
DIGITALOCEAN_TOKEN=

# === Monitoring ===
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=<strong-password>
# Gmail App Password để Alertmanager gửi mail cảnh báo (bỏ trống = tắt email alert)
ALERTMANAGER_EMAIL=
ALERTMANAGER_SMTP_PASSWORD=
