global:
  resolve_timeout: 5m
{% if alert_smtp_password | length > 0 %}
  smtp_smarthost: "{{ alert_smtp_smarthost }}"
  smtp_from: "{{ alert_email }}"
  smtp_auth_username: "{{ alert_email }}"
  smtp_auth_identity: "{{ alert_email }}"
  smtp_auth_password: "{{ alert_smtp_password }}"
  smtp_require_tls: true
{% endif %}

route:
  receiver: default
  group_by: [alertname, job, instance]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 4h

receivers:
  - name: default
{% if alert_smtp_password | length > 0 %}
    email_configs:
      - to: "{{ alert_email }}"
        send_resolved: true
{% endif %}
